*.wav
*.aif
*.aiff
*.flac

# ─── Video files (too large for git) ─────────────────────────────────────────
*.mp4
*.mov
*.avi
*.mkv
*.webm

# ─── Asset source / raw files (exports get committed, sources do not) ─────────
# Aseprite source files
*.aseprite
*.ase

# Audio project files (DAW sources)
*.aup
*.aup3
*.flp
*.ptx
*.logic

# Photoshop / GIMP sources
*.psd
*.xcf

